{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "repeater-production",
  "compatibility_date": "2026-06-22",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "404-page"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
